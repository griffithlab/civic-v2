<%= turbo_stream_from "chats" %>

<aside class="w-72 bg-civic-sidebar text-white flex flex-col h-full shrink-0">
  <%# Header / New Chat %>
  <div class="p-4 border-b border-slate-600">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-lg font-semibold tracking-tight"><a href="<%= new_chats_chat_path %>">CIViC Curation Chat</a></h1>
    </div>
    <details class="new-chat-dropdown relative">
      <summary class="flex items-center gap-2 w-full px-3 py-2.5 rounded-lg bg-civic-purple hover:bg-civic-purple-dark text-white text-sm font-medium transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        New Chat
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-auto opacity-60" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </summary>
      <div class="absolute left-0 right-0 mt-1 bg-slate-700 rounded-lg shadow-lg border border-slate-600 overflow-hidden z-10">
        <%= link_to curation_chat_path, class: "flex items-center gap-2 px-3 py-2.5 text-sm text-slate-200 hover:bg-civic-sidebar-hover hover:text-white transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
          </svg>
          Curation Chat
        <% end %>
        <%= link_to mcp_chat_path, class: "flex items-center gap-2 px-3 py-2.5 text-sm text-slate-200 hover:bg-civic-sidebar-hover hover:text-white transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-amber-400" fill="none" viewBox="10 15 170 185" stroke="currentColor">
            <path d="M25 97.8528L92.8823 29.9706C102.255 20.598 117.451 20.598 126.823 29.9706V29.9706C136.196 39.3431 136.196 54.5391 126.823 63.9117L75.5581 115.177" stroke-width="12" stroke-linecap="round"/>
            <path d="M76.2653 114.47L126.823 63.9117C136.196 54.5391 151.392 54.5391 160.765 63.9117L161.118 64.2652C170.491 73.6378 170.491 88.8338 161.118 98.2063L99.7248 159.6C96.6006 162.724 96.6006 167.789 99.7248 170.913L112.331 183.52" stroke-width="12" stroke-linecap="round"/>
            <path d="M109.853 46.9411L59.6482 97.1457C50.2757 106.518 50.2757 121.714 59.6482 131.087V131.087C69.0208 140.459 84.2168 140.459 93.5894 131.087L143.794 80.8822" stroke-width="12" stroke-linecap="round"/>
          </svg>
          MCP Chat
        <% end %>
      </div>
    </details>
  </div>

  <%# Chat list %>
  <nav class="flex-1 overflow-y-auto p-3 space-y-1">
    <% current_user.chats.order(created_at: :desc).each do |chat| %>
      <%= render "chats/chats/sidebar_chat", chat: chat, current_chat: @chat %>
    <% end %>
  </nav>
</aside>
