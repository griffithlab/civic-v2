<%# Notification bar for share/unshare actions %>
<%# Locals: message (required), url (optional - shows input + Copy button when present) %>
<div id="share_notification" class="px-4 py-2.5 bg-green-50 border-b border-green-200 text-green-800 text-sm flex items-center gap-3">
  <span class="font-medium whitespace-nowrap"><%= message %></span>
  <% if local_assigns[:url].present? %>
    <input type="text" readonly value="<%= url %>"
           class="flex-1 px-2 py-1 text-sm bg-white border border-green-300 rounded text-gray-700 focus:outline-none focus:ring-1 focus:ring-green-400 min-w-0"
           onclick="this.select()">
    <button type="button"
            data-controller="clipboard"
            data-clipboard-text-value="<%= url %>"
            data-action="click->clipboard#copy"
            class="px-3 py-1 text-sm font-medium bg-green-600 text-white rounded hover:bg-green-700 transition-colors whitespace-nowrap">
      Copy
    </button>
  <% else %>
    <span class="flex-1"></span>
  <% end %>
  <button type="button"
          onclick="this.closest('#share_notification').remove()"
          class="p-1 text-green-600 hover:text-green-800 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>
