<% content_for :title, "New Chat" %>

<%
  if @chat_type == "mcp"
    heading = "CIViC Knowledge Chat"
    subtitle = "Ask a question about variant knowledge in CIViC"
  else
    heading = "Curator Help"
    subtitle = "Ask a question about how to curate in CIViC"
  end
%>

<div class="flex-1 flex flex-col overflow-y-auto">
  <div class="w-full px-3 sm:px-6 py-3 border-b border-gray-200 bg-white shrink-0 lg:hidden">
    <button type="button"
            class="inline-flex items-center p-2 -ml-1 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors"
            data-action="click->sidebar#toggle"
            title="Open chats menu"
            aria-label="Open chats menu">
      <%= render "chats/shared/icons/menu", css: "h-5 w-5" %>
    </button>
  </div>

  <div class="flex-1 flex flex-col items-center justify-center p-4 sm:p-8">
    <div class="w-full max-w-xl">
      <%# Logo / welcome %>
      <div class="text-center mb-8">
        <% if @chat_type == "mcp" %>
          <div class="w-16 h-16 rounded-full bg-amber-500 flex items-center justify-center mx-auto mb-4">
            <%= render "chats/shared/icons/mcp_logo", css: "h-8 w-8 text-white" %>
          </div>
        <% else %>
          <div class="w-16 h-16 rounded-full bg-civic-purple flex items-center justify-center mx-auto mb-4">
            <%= render "chats/shared/icons/chat_bubble_solid", css: "h-8 w-8 text-white" %>
          </div>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-800"><%= heading %></h1>
        <p class="text-gray-500 mt-2"><%= subtitle %></p>
        <p class="text-sm text-gray-400 mt-4 max-w-md mx-auto">
          <strong>Knowledge Chat</strong> searches the CIViC knowledgebase to answer questions about variants, evidence, and clinical interpretations.
          <strong>Curator Help</strong> assists with CIViC curation procedures and best practices.
        </p>
      </div>

      <%# Chat type selector tabs %>
      <div class="flex justify-center mb-6">
        <div class="inline-flex rounded-lg bg-gray-100 p-1">
          <%= link_to curation_chat_path, class: "flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium transition-colors #{@chat_type == 'curation' ? 'bg-white text-gray-800 shadow-sm' : 'text-gray-500 hover:text-gray-700'}" do %>
            <%= render "chats/shared/icons/chat_bubble", css: "h-4 w-4" %>
            Curator Help
          <% end %>
          <%= link_to mcp_chat_path, class: "flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium transition-colors #{@chat_type == 'mcp' ? 'bg-white text-gray-800 shadow-sm' : 'text-gray-500 hover:text-gray-700'}" do %>
            <%= render "chats/shared/icons/mcp_logo", css: "h-4 w-4" %>
            Knowledge
          <% end %>
        </div>
      </div>

      <%= render "chats/chats/form", chat: @chat, chat_type: @chat_type %>
    </div>
  </div>
</div>
