<% content_for :title, "Shared Chat" %>

<%# Header bar - read only, no controls %>
<div class="flex items-center justify-between px-6 py-3 bg-civic-sidebar shrink-0">
  <div class="flex items-center gap-3">
    <a href="/" class="shrink-0">
      <img src="/assets/images/civic-logo_sidebar-expanded.png" alt="CIViC" class="h-8">
    </a>
    <div class="h-6 w-px bg-slate-500"></div>
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full bg-slate-600 flex items-center justify-center shrink-0">
        <%= render "chats/shared/icons/beaker", css: "h-4 w-4 text-white" %>
      </div>
      <h1 class="font-semibold text-white"><%= @chat.display_name %></h1>
    </div>
  </div>
  <span class="text-xs text-slate-400">Shared chat &middot; read only</span>
</div>

<%# Messages area - scrollable, read only %>
<div class="flex-1 overflow-y-auto messages-container" data-controller="scroll">
  <div id="messages" class="max-w-4xl mx-auto px-4 py-6 space-y-6">
    <% @chat.messages.where.not(id: nil).each do |message| %>
      <%= render message %>
    <% end %>
  </div>
</div>

<%# Footer - disclaimer only, no input %>
<div class="shrink-0 border-t border-gray-200 bg-white">
  <div class="max-w-4xl mx-auto px-4 py-3">
    <%= render "chats/shared/disclaimer" %>
  </div>
</div>
