<div class="group relative" data-controller="inline-edit" data-inline-edit-url-value="<%= chats_chat_path(chat) %>">
  <% chat_prefix = chat.mcp? ? "MCP" : "Curation" %>
  <% chat_tooltip = "#{chat_prefix}: #{chat.display_name}" %>
  <%= link_to chats_chat_path(chat),
        id: "sidebar_chat_#{chat.id}",
        title: chat_tooltip,
        class: "block px-3 py-2.5 rounded-lg text-sm transition-colors #{chat.id == current_chat&.id ? 'bg-slate-600 text-white' : 'text-slate-300 hover:bg-civic-sidebar-hover hover:text-white'}" do %>
    <div class="flex items-center gap-2">
      <% if chat.mcp? %>
        <%= render "chats/shared/icons/mcp_logo", css: "h-4 w-4 shrink-0 text-amber-400" %>
      <% else %>
        <%= render "chats/shared/icons/chat_bubble", css: "h-4 w-4 shrink-0 text-slate-400" %>
      <% end %>
      <div class="truncate pr-6">
        <div class="truncate font-medium" data-inline-edit-target="display"><%= chat.display_name %></div>
        <div class="hidden" data-inline-edit-target="form">
          <input type="text"
                 data-inline-edit-target="input"
                 data-action="keydown->inline-edit#keydown blur->inline-edit#save"
                 class="w-full bg-slate-700 text-white text-sm rounded px-1 py-0.5 border border-slate-500 focus:border-civic-purple focus:outline-none"
                 onclick="event.preventDefault(); event.stopPropagation();" />
        </div>
        <div class="text-xs text-slate-400 truncate"><%= chat.created_at.strftime("%b %d, %I:%M %p") %></div>
      </div>
    </div>
  <% end %>

  <%# Popover menu trigger %>
  <div class="absolute right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all" data-controller="popover">
    <button type="button"
            data-action="click->popover#toggle"
            class="p-1 rounded text-slate-400 hover:text-white transition-colors"
            title="Chat options">
      <%= render "chats/shared/icons/ellipsis_vertical", css: "h-4 w-4" %>
    </button>

    <%# Dropdown menu %>
    <div data-popover-target="menu"
         class="hidden absolute right-0 top-full mt-1 w-36 bg-slate-700 rounded-lg shadow-lg border border-slate-600 py-1 z-50">
      <button type="button"
              data-action="click->inline-edit#activate click->popover#close"
              class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-200 hover:bg-slate-600 transition-colors">
        <%= render "chats/shared/icons/pencil", css: "h-3.5 w-3.5" %>
        Rename
      </button>
      <%= button_to chats_chat_path(chat), method: :delete,
            data: { turbo_confirm: "Are you sure you want to delete this chat?" },
            class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-slate-600 transition-colors" do %>
        <%= render "chats/shared/icons/trash", css: "h-3.5 w-3.5" %>
        Delete
      <% end %>
    </div>
  </div>
</div>
