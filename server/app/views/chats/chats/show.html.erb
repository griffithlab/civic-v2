<%= turbo_stream_from "chats_chat_#{@chat.id}" %>

<% content_for :title, "Chat" %>

<%# Header bar %>
<div class="flex items-center justify-between px-6 py-3 border-b border-gray-200 bg-white shrink-0">
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-civic-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
      </svg>
    </div>
    <div>
      <h1 class="font-semibold text-gray-800"><%= render "chats/chats/header_name", chat: @chat %></h1>
      <p class="text-xs text-gray-500">Chat #<%= @chat.id %></p>
    </div>
  </div>
</div>

<%# Messages area - scrollable %>
<div class="flex-1 overflow-y-auto messages-container" data-controller="scroll">
  <div id="messages" class="max-w-4xl mx-auto px-4 py-6 space-y-6">
    <% @chat.messages.where.not(id: nil).each do |message| %>
      <%= render message %>
    <% end %>
  </div>
</div>

<%# Input area - fixed at bottom %>
<div class="shrink-0 border-t border-gray-200 bg-white">
  <div class="max-w-4xl mx-auto px-4 py-4">
    <%= render "chats/messages/form", chat: @chat, message: @message %>
  </div>
</div>
