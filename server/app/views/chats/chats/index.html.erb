<% content_for :title, "Chats" %>

<%= turbo_stream_from "chats" %>

<div class="flex-1 flex flex-col items-center justify-center p-8">
  <% if @chats.any? %>
    <div class="w-full max-w-2xl">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">Your Chats</h1>
      <div class="space-y-2">
        <% @chats.each do |chat| %>
          <%= render "chats/chats/index_chat", chat: chat %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="text-center">
      <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-civic-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-gray-700 mb-2">No chats yet</h2>
      <p class="text-gray-500 mb-6">Start a conversation with the CIViC curation assistant</p>
      <%= link_to "Start a new chat", new_chats_chat_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-civic-purple hover:bg-civic-purple-dark text-white font-medium transition-colors" %>
    </div>
  <% end %>
</div>
