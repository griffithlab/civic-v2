<% content_for :title, "Chats" %>

<%= turbo_stream_from current_user, "chats" %>

<div class="flex-1 flex flex-col items-center overflow-y-auto p-8 <%= @chats.any? ? '' : 'justify-center' %>">
  <% if @chats.any? %>
    <div class="w-full max-w-2xl">
      <h1 class="text-2xl font-bold text-gray-800 mb-6">Your Chats</h1>
      <div class="space-y-2">
        <% @chats.each do |chat| %>
          <%= render "chats/chats/index_chat", chat: chat %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="text-center">
      <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center mx-auto mb-4">
        <%= render "chats/shared/icons/chat_bubble", css: "h-8 w-8 text-civic-purple" %>
      </div>
      <h2 class="text-xl font-semibold text-gray-700 mb-2">No chats yet</h2>
      <p class="text-gray-500 mb-6">Start a conversation with the CIViC curation assistant</p>
      <%= link_to "Start a new chat", new_chats_chat_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-civic-purple hover:bg-civic-purple-dark text-white font-medium transition-colors" %>
    </div>
  <% end %>
</div>
