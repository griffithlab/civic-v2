<div id="<%= dom_id chat %>" class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-100 transition-colors">
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center shrink-0">
      <%= render "chats/shared/icons/chat_bubble", css: "h-4 w-4 text-civic-purple" %>
    </div>
    <div>
      <div class="font-medium text-gray-800 text-sm"><%= chat.display_name %></div>
      <div class="text-xs text-gray-500"><%= chat.messages.count %> messages</div>
    </div>
  </div>
  <time class="text-xs text-gray-400" datetime="<%= chat.created_at.iso8601 %>" data-controller="local-time" data-local-time-format-value="date"><%= chat.created_at.strftime("%b %d") %></time>
</div>
