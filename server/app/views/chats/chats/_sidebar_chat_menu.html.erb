<%# Sidebar popover menu for chat options (Rename, Share/Copy Link/Unshare, Delete) %>
<%# Wrapped in a replaceable div so turbo streams can swap it after share/unshare %>
<div id="chat_menu_sidebar_<%= chat.id %>"
     class="absolute right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all">
  <div data-controller="popover">
    <button type="button"
            data-action="click->popover#toggle"
            class="p-1 rounded text-slate-400 hover:text-white transition-colors"
            title="Chat options">
      <%= render "chats/shared/icons/ellipsis_vertical", css: "h-4 w-4" %>
    </button>

    <div data-popover-target="menu"
         class="hidden absolute right-0 top-full mt-1 w-40 bg-slate-700 rounded-lg shadow-lg border border-slate-600 py-1 z-50">
      <button type="button"
              data-action="click->inline-edit#activate click->popover#close"
              class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-200 hover:bg-slate-600 transition-colors">
        <%= render "chats/shared/icons/pencil", css: "h-3.5 w-3.5" %>
        Rename
      </button>
      <% if chat.shared? %>
        <button type="button"
                data-controller="clipboard"
                data-clipboard-text-value="<%= shared_chat_url(chat.public_id) %>"
                data-action="click->clipboard#copy click->popover#close"
                class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-200 hover:bg-slate-600 transition-colors">
          <%= render "chats/shared/icons/link", css: "h-3.5 w-3.5" %>
          Copy Link
        </button>
        <%= button_to unshare_chats_chat_path(chat), method: :delete,
              data: { turbo_confirm: "Remove public access to this chat? Existing shared links will stop working." },
              class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-amber-400 hover:bg-slate-600 transition-colors" do %>
          <%= render "chats/shared/icons/no_share", css: "h-3.5 w-3.5" %>
          Unshare
        <% end %>
      <% else %>
        <%= button_to share_chats_chat_path(chat),
              data: { turbo_confirm: "Make this chat publicly accessible? Anyone with the link will be able to view it." },
              class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-200 hover:bg-slate-600 transition-colors" do %>
          <%= render "chats/shared/icons/share", css: "h-3.5 w-3.5" %>
          Share
        <% end %>
      <% end %>
      <div class="border-t border-slate-600 my-1"></div>
      <%= button_to chats_chat_path(chat), method: :delete,
            data: { turbo_confirm: "Are you sure you want to delete this chat?" },
            class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-slate-600 transition-colors" do %>
        <%= render "chats/shared/icons/trash", css: "h-3.5 w-3.5" %>
        Delete
      <% end %>
    </div>
  </div>
</div>
