<% content_for :title, @model.name %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-3xl mx-auto px-6 py-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-12 rounded-full bg-purple-100 flex items-center justify-center">
          <%= render "chats/shared/icons/beaker", css: "h-6 w-6 text-civic-purple" %>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-gray-800"><%= @model.name %></h1>
          <p class="text-sm text-gray-500"><%= @model.model_id %></p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Provider</div>
          <div class="text-gray-800 font-medium"><%= @model.provider %></div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Context Window</div>
          <div class="text-gray-800 font-medium"><%= number_with_delimiter(@model.context_window) %> tokens</div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Max Output</div>
          <div class="text-gray-800 font-medium"><%= number_with_delimiter(@model.max_output_tokens) %> tokens</div>
        </div>
        <% if @model.capabilities.any? %>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Capabilities</div>
            <div class="flex flex-wrap gap-1.5 mt-1">
              <% @model.capabilities.each do |cap| %>
                <span class="inline-block px-2 py-0.5 rounded-full bg-purple-100 text-civic-purple text-xs font-medium"><%= cap %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
        <%= link_to new_chats_chat_path(model: @model.model_id), class: "px-4 py-2 rounded-lg bg-civic-purple hover:bg-civic-purple-dark text-white text-sm font-medium transition-colors" do %>
          Start chat with this model
        <% end %>
        <%= link_to "All models", chats_models_path, class: "px-4 py-2 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors" %>
        <%= link_to "Back to chats", chats_root_path, class: "px-4 py-2 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors" %>
      </div>
    </div>
  </div>
</div>
