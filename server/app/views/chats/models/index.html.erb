<% content_for :title, "Models" %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-800">AI Models</h1>
      <div class="flex items-center gap-3">
        <%= button_to "Refresh Models", refresh_chats_models_path, method: :post, class: "px-4 py-2 rounded-lg bg-civic-purple hover:bg-civic-purple-dark text-white text-sm font-medium transition-colors cursor-pointer" %>
        <%= link_to "Back to chats", chats_root_path, class: "px-4 py-2 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50 transition-colors" %>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Provider</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Model</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Context Window</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">$/1M tokens (In/Out)</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <%= render @models %>
        </tbody>
      </table>
    </div>
  </div>
</div>
