<%= form_with(model: message, scope: :message, url: chats_chat_messages_path(chat), id: "new_message", class: "flex items-end gap-3") do |form| %>
  <% if message.errors.any? %>
    <div class="text-red-600 text-sm mb-2">
      <% message.errors.each do |error| %>
        <p><%= error.full_message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="flex-1 relative">
    <%= form.text_field :content,
        class: "w-full px-4 py-3 rounded-xl border border-gray-300 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-civic-purple focus:border-transparent text-gray-800 placeholder-gray-400 transition-shadow",
        placeholder: "Send a message...",
        autofocus: true,
        autocomplete: "off" %>
  </div>

  <%= form.submit "Send",
      class: "px-6 py-3 rounded-xl bg-civic-purple hover:bg-civic-purple-dark text-white font-medium shadow-sm transition-colors cursor-pointer" %>
<% end %>
