<div id="typing_placeholder" class="message">
  <div class="flex items-start gap-3">
    <%# Assistant avatar %>
    <div class="w-9 h-9 rounded-full bg-civic-purple flex items-center justify-center shrink-0">
      <%= render "chats/shared/icons/chat_bubble_solid", css: "h-5 w-5 text-white" %>
    </div>
    <div class="max-w-3xl flex-1">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-sm font-semibold text-civic-purple">CIViC Bot</span>
      </div>
      <div class="bg-civic-purple-light rounded-2xl rounded-tl-sm px-5 py-4 shadow-sm border border-purple-200">
        <div class="message-content leading-relaxed text-gray-800">
          <div class="flex items-center gap-1.5 py-1">
            <span class="typing-dot w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
            <span class="typing-dot w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
            <span class="typing-dot w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
